{
    "wordPattern": "(<\\/?[a-zA-Z][a-zA-Z0-9:_-]*|[a-zA-Z][a-zA-Z0-9_$-]*)",
    "comments": {
        "blockComment": [ "<!--", "-->" ]
    },
    "brackets": [
        ["<!--", "-->"],
        ["<", ">"],
        ["{", "}"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}"},
        { "open": "[", "close": "]"},
        { "open": "(", "close": ")" },
        { "open": "'", "close": "'" },
        { "open": "\"", "close": "\"" },
        { "open": "<!--", "close": "-->", "notIn": [ "comment", "string" ]}
    ],
    "surroundingPairs": [
        { "open": "'", "close": "'" },
        { "open": "\"", "close": "\"" },
        { "open": "{", "close": "}"},
        { "open": "[", "close": "]"},
        { "open": "(", "close": ")" },
        { "open": "<", "close": ">" }
    ],
    "folding": {
        "markers": {
            "start": "^\\s*<!--\\s*#region\\b.*-->",
            "end": "^\\s*<!--\\s*#endregion\\b.*-->"
        }
    }
}